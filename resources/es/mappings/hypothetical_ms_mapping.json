{
  "settings": {
    "index": { "number_of_shards": 1, "number_of_replicas": 0 },
    "analysis": { "normalizer": { "lc": { "type": "custom", "filter": ["lowercase"] } } }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "id": { "type": "keyword" },
      "profile": { "type": "keyword" },

      "repository": {
        "properties": {
          "name": { "type": "keyword", "normalizer": "lc" },
          "identifier": { "type": "keyword", "normalizer": "lc" },
          "revision": { "type": "integer" }
        }
      },

      "study": {
        "properties": {
          "title": { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
          "description": { "type": "text" },
          "license": { "type": "keyword" },
          "dataset_urls": { "type": "keyword" },
          "mhd_identifier": { "type": "keyword" }
        }
      },

      "dates": {
        "properties": {
          "submission": { "type": "date" },
          "public_release": { "type": "date" },
          "indexed": { "type": "date" }
        }
      },

      "facets": {
        "properties": {
          "organisms": { "type": "keyword" },
          "organism_accessions": { "type": "keyword" },
          "diseases": { "type": "keyword" },
          "disease_accessions": { "type": "keyword" },
          "tissues": { "type": "keyword" },
          "sample_types": { "type": "keyword" },

          "omics_types": { "type": "keyword" },
          "measurement_types": { "type": "keyword" },
          "assay_types": { "type": "keyword" },
          "technology_types": { "type": "keyword" },

          "protocol_types": { "type": "keyword" },
          "parameter_types": { "type": "keyword" },
          "parameter_values": { "type": "keyword" }
        }
      },

      "counts": {
        "properties": {
          "assays": { "type": "integer" },
          "samples": { "type": "integer" },
          "sample_runs": { "type": "integer" },
          "subjects": { "type": "integer" }
        }
      },

      "files": {
        "properties": {
          "metadata": { "properties": { "count": { "type": "integer" } } },
          "raw": { "properties": { "count": { "type": "integer" } } },
          "derived": { "properties": { "count": { "type": "integer" } } },
          "result": { "properties": { "count": { "type": "integer" } } },
          "supplementary": { "properties": { "count": { "type": "integer" } } }
        }
      },

      "people": {
        "type": "nested",
        "properties": {
          "full_name": { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
          "emails": { "type": "keyword" },
          "organizations": { "type": "keyword" },
          "roles": { "type": "keyword" }
        }
      },

      "project": {
        "properties": {
          "title": { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } } },
          "managed_by": { "type": "keyword" }
        }
      },

      "search_text": { "type": "text" },
      "debug": { "type": "object", "enabled": false }
    }
  }
}
